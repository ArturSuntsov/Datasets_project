# =============================================================================
# Dataset AI Platform - Environment Variables Template
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями:
#   cp .env.example .env
#
# Для генерации случайных ключей используйте:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# =============================================================================

# =============================================================================
# ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ (необходимы для запуска)
# =============================================================================

# Секретный ключ Django (генерируется командой выше)
SECRET_KEY=generate-a-random-secret-key-here-min-50-chars

# JWT секретный ключ (можно использовать тот же, что и SECRET_KEY)
JWT_SECRET_KEY=generate-a-random-jwt-secret-key-here-min-50-chars

# MongoDB URI (для Docker Compose используйте имя сервиса "db")
# Формат: mongodb://[user:password@]host:port/database?options
MONGO_URI=mongodb://db:27017/ai_dataset_db?serverSelectionTimeoutMS=5000&connectTimeoutMS=5000

# =============================================================================
# ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ (значения по умолчанию подходят для разработки)
# =============================================================================

# Режим отладки (True = разработка, False = production)
DEBUG=True

# Разрешенные хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web

# CORS разрешенные origin (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Количество раундов bcrypt (4 = разработка, 12 = production)
BCRYPT_ROUNDS=4

# Redis настройки
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend URL для API (внутри Docker сети)
VITE_API_URL=http://web:8000

# =============================================================================
# PRODUCTION НАСТРОЙКИ (оставьте пустыми для разработки)
# =============================================================================

# MongoDB аутентификация (если требуется)
MONGODB_DB=ai_dataset_db
MONGODB_USER=
MONGODB_PASSWORD=

# Email настройки (для отправки уведомлений)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Stripe ключи (для приёма платежей)
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# S3/MinIO настройки (для хранения файлов)
AWS_S3_ENDPOINT_URL=
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=

# =============================================================================
# ТЕСТОВЫЕ НАСТРОЙКИ (только для pytest)
# =============================================================================

# Пароли для тестовых пользователей (НЕ используются в production!)
TEST_PASSWORD=test-password-for-dev-only
TEST_ADMIN_PASSWORD=test-admin-password-for-dev-only
