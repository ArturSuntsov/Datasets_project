# Шаблон переменных окружения для проекта
# Скопируйте этот файл в .env и заполните значения

# =============================================================================
# ОБЩИЕ НАСТРОЙКИ
# =============================================================================

# Режим отладки (False для production!)
DEBUG=True

# Секретный ключ Django (обязательно измените для production!)
# Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-me-in-production

# Количество раундов bcrypt для хеширования паролей
# Разработка: 4 (быстро, ~100ms), Production: 12+ (безопасно, ~300ms)
BCRYPT_ROUNDS=4

# Разрешенные хосты (домены)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS разрешенные origin
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# =============================================================================
# MONGODB НАСТРОЙКИ
# =============================================================================

# URI подключения к MongoDB (основной способ для mongoengine)
# Для локальной разработки:
MONGO_URI=mongodb://localhost:27017/ai_dataset_db?serverSelectionTimeoutMS=5000&connectTimeoutMS=5000
# Для Docker Compose (раскомментировать):
# MONGO_URI=mongodb://db:27017/ai_dataset_db?serverSelectionTimeoutMS=5000&connectTimeoutMS=5000
# Для production с аутентификацией:
# MONGO_URI=mongodb://user:password@db:27017/ai_dataset_db?authSource=admin&serverSelectionTimeoutMS=5000&connectTimeoutMS=5000

# Хост MongoDB (для Docker Compose используйте имя сервиса)
MONGODB_HOST=localhost
# Для production Docker: MONGODB_HOST=mongodb

# Порт MongoDB
MONGODB_PORT=27017

# Имя базы данных
MONGODB_DB=ai_dataset_db

# Пользователь MongoDB (опционально, для production)
MONGODB_USER=
MONGODB_PASSWORD=

# =============================================================================
# REDIS НАСТРОЙКИ
# =============================================================================

# URL Redis (основной способ)
# Для локальной разработки:
REDIS_URL=redis://localhost:6379/0
# Для Docker Compose (раскомментировать):
# REDIS_URL=redis://redis:6379/0

# Хост Redis (для Docker Compose используйте имя сервиса)
REDIS_HOST=localhost
# Для production Docker: REDIS_HOST=redis

# Порт Redis
REDIS_PORT=6379

# БД Redis (0-15)
REDIS_DB=0

# Пароль Redis (опционально)
REDIS_PASSWORD=

# =============================================================================
# JWT НАСТРОЙКИ
# =============================================================================

# Секретный ключ для JWT (можно использовать SECRET_KEY)
JWT_SECRET_KEY=${SECRET_KEY}

# Алгоритм подписи JWT
JWT_ALGORITHM=HS256

# Время жизни access токена (минуты)
JWT_ACCESS_TTL_MINUTES=60

# Время жизни refresh токена (минуты)
JWT_REFRESH_TTL_MINUTES=1440

# =============================================================================
# НАСТРОЙКИ БЕЗОПАСНОСТИ
# =============================================================================

# HTTPS в production
SECURE_SSL_REDIRECT=False

# HSTS (для production)
SECURE_HSTS_SECONDS=0

# CSRF cookie Secure
CSRF_COOKIE_SECURE=False

# Session cookie Secure
SESSION_COOKIE_SECURE=False

# =============================================================================
# ЛОГИРОВАНИЕ
# =============================================================================

# Уровень логов Django
DJANGO_LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=logs/django.log

# Путь к файлу security логов
SECURITY_LOG_FILE=logs/security.log

# =============================================================================
# CELERY НАСТРОЙКИ
# =============================================================================

# Брокер URL для Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Backend для результатов Celery
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Timezone для Celery
CELERY_TIMEZONE=UTC

# =============================================================================
# EMAIL НАСТРОЙКИ (опционально)
# =============================================================================

# Email backend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP сервер
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# STRIPE НАСТРОЙКИ (опционально)
# =============================================================================

# Stripe API ключи (для production используйте real keys)
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# S3/MINIO НАСТРОЙКИ (опционально, для хранения файлов)
# =============================================================================

# S3 Endpoint (для MinIO или совместимого хранилища)
AWS_S3_ENDPOINT_URL=

# S3 Bucket
AWS_STORAGE_BUCKET_NAME=

# S3 Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=

# =============================================================================
# ПРОЧИЕ НАСТРОЙКИ
# =============================================================================

# Максимальный размер загружаемых файлов (байты)
MAX_UPLOAD_SIZE=10485760

# Разрешенные расширения файлов
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,zip,csv,json

# Rate limiting (запросов в час)
ANON_RATE_LIMIT=100
USER_RATE_LIMIT=1000
LOGIN_RATE_LIMIT=10
REGISTER_RATE_LIMIT=5
