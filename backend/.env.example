# =============================================================================
# REQUIRED: Security (must be set in production!)
# =============================================================================
# Генерируйте надежные случайные строки (не менее 50 символов)
# Пример: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=<ваш-seкретный-ключ>
JWT_SECRET_KEY=<ваш-jwt-секретный-ключ>

# =============================================================================
# REQUIRED: Database
# =============================================================================
# Для локальной разработки:
MONGO_URI=mongodb://localhost:27017/ai_dataset_db?serverSelectionTimeoutMS=5000&connectTimeoutMS=5000

# Для Docker (раскомментировать и использовать в docker-compose):
# MONGO_URI=mongodb://db:27017/ai_dataset_db?serverSelectionTimeoutMS=5000&connectTimeoutMS=5000

# С аутентификацией (для production):
# MONGO_URI=mongodb://user:password@db:27017/ai_dataset_db?authSource=admin&serverSelectionTimeoutMS=5000&connectTimeoutMS=5000

# =============================================================================
# Optional settings
# =============================================================================
# Bcrypt настройки
# Разработка: 4 раунда (быстро, ~100ms)
# Production: 12 раундов (безопасно, ~300ms)
BCRYPT_ROUNDS=4

# Redis (опционально, используется для кэширования)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Debug mode
DEBUG=True