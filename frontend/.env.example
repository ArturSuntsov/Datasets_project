# Frontend переменные окружения
# =============================================================================

# ✅ URL backend БЕЗ /api в конце - Vite proxy сам добавит путь
# Для локальной разработки:
VITE_API_URL=http://localhost:8000

# Для Docker (если frontend в контейнере):
# VITE_API_URL=http://web:8000

# Для production:
# VITE_API_URL=https://api.your-domain.com
